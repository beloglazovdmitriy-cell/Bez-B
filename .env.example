# Скопируй этот файл в .env и заполни значения.

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456:ABC-DEF...

# Твой Telegram user id (узнать у @userinfobot). Только ты сможешь менять портфель.
ADMIN_ID=0

# ID или @username канала для автопубликации. Можно оставить пустым на старте.
CHANNEL_ID=
# Архивный ежедневный AI-конвейер. После перезапуска продукта оставлять false.
LEGACY_CONTENT_SCHEDULE_ENABLED=false
